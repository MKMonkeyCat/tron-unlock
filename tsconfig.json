{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "lib": ["ES2023", "DOM"],

    "moduleResolution": "bundler",
    "noEmit": true,

    "resolveJsonModule": true,

    "jsx": "react-jsx",
    "jsxImportSource": "preact",

    "skipLibCheck": true,

    "paths": {
      "@": ["./src"],
      "@/*": ["./src/*"],

      "@@": ["./extension"],
      "@@/*": ["./extension/*"]
    }
  },

  "exclude": ["node_modules", "dist"]
}
